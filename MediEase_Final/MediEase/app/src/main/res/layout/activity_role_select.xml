<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="match_parent"
    android:orientation="vertical" android:background="@color/oat">

    <!-- Header -->
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="vertical" android:gravity="center"
        android:background="@color/lavender"
        android:paddingTop="52dp" android:paddingBottom="28dp" android:paddingHorizontal="24dp">

        <FrameLayout android:layout_width="68dp" android:layout_height="68dp">
            <View android:layout_width="match_parent" android:layout_height="match_parent"
                android:background="@drawable/bg_circle_lavender"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:layout_gravity="center" android:text="💊" android:textSize="26sp"/>
        </FrameLayout>

        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="Who are you?" android:textSize="24sp" android:fontFamily="@font/nunito"
            android:textStyle="bold" android:textColor="@color/charcoal" android:layout_marginTop="12dp"/>
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="Choose your role to personalise your experience"
            android:textSize="14sp" android:textColor="@color/charcoal_light"
            android:gravity="center" android:maxWidth="240dp" android:layout_marginTop="6dp"/>
    </LinearLayout>

    <!-- Role Cards -->
    <LinearLayout android:layout_width="match_parent" android:layout_height="0dp"
        android:layout_weight="1" android:orientation="horizontal"
        android:padding="20dp" android:gravity="center">

        <!-- Patient Card -->
        <androidx.cardview.widget.CardView android:id="@+id/card_patient"
            android:layout_width="0dp" android:layout_height="200dp" android:layout_weight="1"
            app:cardCornerRadius="22dp" app:cardElevation="4dp"
            app:cardBackgroundColor="@color/white"
            android:layout_marginEnd="7dp"
            xmlns:app="http://schemas.android.com/apk/res-auto">
            <LinearLayout android:layout_width="match_parent" android:layout_height="match_parent"
                android:orientation="vertical" android:gravity="center" android:padding="14dp">
                <FrameLayout android:layout_width="68dp" android:layout_height="68dp">
                    <View android:layout_width="match_parent" android:layout_height="match_parent"
                        android:background="@drawable/bg_circle_lavender"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:layout_gravity="center" android:text="🧑‍⚕️" android:textSize="30sp"/>
                </FrameLayout>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Patient" android:textSize="19sp" android:fontFamily="@font/nunito"
                    android:textStyle="bold" android:textColor="@color/charcoal" android:layout_marginTop="10dp"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Manage my own medications and reminders"
                    android:textSize="12sp" android:textColor="@color/charcoal_light"
                    android:gravity="center" android:layout_marginTop="6dp"/>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Caregiver Card -->
        <androidx.cardview.widget.CardView android:id="@+id/card_caregiver"
            android:layout_width="0dp" android:layout_height="200dp" android:layout_weight="1"
            app:cardCornerRadius="22dp" app:cardElevation="4dp"
            app:cardBackgroundColor="@color/white" android:layout_marginStart="7dp"
            xmlns:app="http://schemas.android.com/apk/res-auto">
            <LinearLayout android:layout_width="match_parent" android:layout_height="match_parent"
                android:orientation="vertical" android:gravity="center" android:padding="14dp">
                <FrameLayout android:layout_width="68dp" android:layout_height="68dp">
                    <View android:layout_width="match_parent" android:layout_height="match_parent"
                        android:background="@drawable/bg_circle_coral_light"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:layout_gravity="center" android:text="🤝" android:textSize="30sp"/>
                </FrameLayout>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Caregiver" android:textSize="19sp" android:fontFamily="@font/nunito"
                    android:textStyle="bold" android:textColor="@color/charcoal" android:layout_marginTop="10dp"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Monitor and support a patient's schedule"
                    android:textSize="12sp" android:textColor="@color/charcoal_light"
                    android:gravity="center" android:layout_marginTop="6dp"/>
            </LinearLayout>
        </androidx.cardview.widget.CardView>
    </LinearLayout>

    
</LinearLayout>
