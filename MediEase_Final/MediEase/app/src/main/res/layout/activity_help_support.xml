<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent" android:layout_height="match_parent"
    android:orientation="vertical" android:background="@color/oat">

    <!-- Header -->
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:background="@color/lavender" android:paddingTop="48dp" android:paddingBottom="20dp"
        android:paddingHorizontal="16dp" android:gravity="center_vertical">
        <Button android:id="@+id/btn_back" android:layout_width="56dp" android:layout_height="56dp"
            android:text="←" android:background="@null" android:textSize="32sp"
            android:textColor="@color/charcoal" android:stateListAnimator="@null"
            android:gravity="center" android:padding="0dp"/>
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="Help &amp; Support" android:textSize="22sp" android:fontFamily="@font/nunito"
            android:textStyle="bold" android:textColor="@color/charcoal" android:paddingStart="4dp"/>
    </LinearLayout>

    <ScrollView android:layout_width="match_parent" android:layout_height="match_parent">
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="vertical" android:padding="20dp">

            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="How can we help you?" android:textSize="20sp"
                android:fontFamily="@font/nunito" android:textStyle="bold"
                android:textColor="@color/charcoal" android:layout_marginBottom="16dp"/>

            <!-- FAQ Section -->
            <androidx.cardview.widget.CardView android:layout_width="match_parent"
                android:layout_height="wrap_content" android:layout_marginBottom="16dp"
                app:cardCornerRadius="16dp" app:cardElevation="2dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@color/lavender"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="12dp"
                        android:fontFamily="@font/nunito"
                        android:text="Frequently Asked Questions"
                        android:textColor="@color/lavender_deeper"
                        android:textSize="17sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="4dp"
                        android:text="Q: How do I add a new medicine?"
                        android:textColor="@color/charcoal"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="12dp"
                        android:text="A: Go to the 'Medicine' tab and tap the '+' button at the bottom."
                        android:textColor="@color/charcoal_light" />

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:layout_marginBottom="12dp"
                        android:background="@color/oat" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="4dp"
                        android:text="Q: How do I connect with my caregiver?"
                        android:textColor="@color/charcoal"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="4dp"
                        android:text="A: Share the 5-digit code from your profile with your caregiver."
                        android:textColor="@color/charcoal_light" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Contact Section -->
            <androidx.cardview.widget.CardView android:layout_width="match_parent"
                android:layout_height="wrap_content" app:cardCornerRadius="16dp"
                app:cardElevation="2dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@color/lavender"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="12dp"
                        android:fontFamily="@font/nunito"
                        android:text="Contact Support"
                        android:textColor="@color/lavender_deeper"
                        android:textSize="17sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="4dp"
                        android:text="📧 Email us at:"
                        android:textColor="@color/charcoal" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="12dp"
                        android:fontFamily="monospace"
                        android:text="support@mediease.app"
                        android:textColor="@color/coral"
                        android:textSize="18sp" />

                    <Button
                        android:id="@+id/btn_email_support"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:background="@drawable/bg_btn_coral"
                        android:stateListAnimator="@null"
                        android:text="Send Email"
                        android:textColor="@color/white" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

        </LinearLayout>
    </ScrollView>
</LinearLayout>
