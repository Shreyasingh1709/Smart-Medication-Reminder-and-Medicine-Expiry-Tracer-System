<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.MediEase" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="colorPrimary">@color/lavender_deep</item>
        <item name="colorPrimaryVariant">@color/lavender_deeper</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="colorSecondary">@color/coral</item>
        <item name="colorSecondaryVariant">@color/coral_dark</item>
        <item name="colorOnSecondary">@color/white</item>
        <item name="android:colorBackground">@color/oat</item>
        <item name="colorSurface">@color/white</item>
        <item name="colorOnSurface">@color/charcoal</item>
        <item name="android:windowBackground">@color/oat</item>
        <item name="android:fontFamily">@font/nunito</item>
        <item name="fontFamily">@font/nunito</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:windowLightStatusBar">true</item>
        <item name="android:navigationBarColor">@color/white</item>
    </style>

    <style name="Theme.MediEase.Splash" parent="Theme.MediEase">
        <item name="android:windowBackground">@drawable/splash_background</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
    </style>

    <!-- Text Styles -->
    <style name="TextStyle.Hero" parent="">
        <item name="android:fontFamily">@font/nunito_black</item>
        <item name="android:textSize">@dimen/text_hero</item>
        <item name="android:textColor">@color/lavender_deeper</item>
    </style>

    <style name="TextStyle.Title" parent="">
        <item name="android:fontFamily">@font/nunito_bold</item>
        <item name="android:textSize">@dimen/text_xxl</item>
        <item name="android:textColor">@color/charcoal</item>
    </style>

    <style name="TextStyle.Subtitle" parent="">
        <item name="android:fontFamily">@font/nunito_semibold</item>
        <item name="android:textSize">@dimen/text_md</item>
        <item name="android:textColor">@color/charcoal_light</item>
    </style>

    <style name="TextStyle.Body" parent="">
        <item name="android:fontFamily">@font/nunito</item>
        <item name="android:textSize">@dimen/text_md</item>
        <item name="android:textColor">@color/charcoal</item>
    </style>

    <style name="TextStyle.Caption" parent="">
        <item name="android:fontFamily">@font/nunito_semibold</item>
        <item name="android:textSize">@dimen/text_xs</item>
        <item name="android:textColor">@color/charcoal_light</item>
    </style>

    <!-- Button Styles -->
    <style name="ButtonStyle.Primary" parent="Widget.MaterialComponents.Button">
        <item name="android:layout_height">@dimen/btn_height_primary</item>
        <item name="android:textSize">@dimen/text_lg</item>
        <item name="android:fontFamily">@font/nunito_bold</item>
        <item name="backgroundTint">@color/coral</item>
        <item name="android:textColor">@color/white</item>
        <item name="cornerRadius">@dimen/radius_pill</item>
        <item name="elevation">6dp</item>
    </style>

    <style name="ButtonStyle.Secondary" parent="Widget.MaterialComponents.Button.OutlinedButton">
        <item name="android:layout_height">@dimen/btn_height_secondary</item>
        <item name="android:textSize">@dimen/text_md</item>
        <item name="android:fontFamily">@font/nunito_bold</item>
        <item name="strokeColor">@color/oat_dark</item>
        <item name="android:textColor">@color/charcoal</item>
        <item name="cornerRadius">@dimen/radius_pill</item>
    </style>

    <!-- Card Style -->
    <style name="CardStyle.Default" parent="Widget.MaterialComponents.CardView">
        <item name="cardCornerRadius">@dimen/radius_md</item>
        <item name="cardElevation">@dimen/card_elevation</item>
        <item name="cardBackgroundColor">@color/white</item>
        <item name="android:layout_marginBottom">@dimen/card_margin</item>
    </style>

    <!-- Input field style -->
    <style name="InputStyle" parent="Widget.MaterialComponents.TextInputLayout.FilledBox">
        <item name="boxBackgroundColor">@color/oat</item>
        <item name="boxCornerRadiusTopStart">@dimen/field_radius</item>
        <item name="boxCornerRadiusTopEnd">@dimen/field_radius</item>
        <item name="boxCornerRadiusBottomStart">@dimen/field_radius</item>
        <item name="boxCornerRadiusBottomEnd">@dimen/field_radius</item>
        <item name="hintTextColor">@color/charcoal_light</item>
        <item name="android:textColorHint">@color/charcoal_light</item>
    </style>

    <!-- Tab Layout -->
    <style name="TabStyle" parent="Widget.MaterialComponents.TabLayout">
        <item name="tabSelectedTextColor">@color/coral</item>
        <item name="tabTextColor">@color/charcoal_light</item>
        <item name="tabIndicatorColor">@color/coral</item>
        <item name="tabBackground">@android:color/transparent</item>
        <item name="tabTextAppearance">@style/TabTextAppearance</item>
    </style>

    <style name="TabTextAppearance" parent="TextAppearance.Design.Tab">
        <item name="android:textSize">@dimen/text_sm</item>
        <item name="android:fontFamily">@font/nunito_bold</item>
        <item name="textAllCaps">false</item>
    </style>

    <!-- Chip Style -->
    <style name="ChipStyle" parent="Widget.MaterialComponents.Chip.Choice">
        <item name="chipBackgroundColor">@color/white</item>
        <item name="chipStrokeColor">@color/oat_dark</item>
        <item name="chipStrokeWidth">2dp</item>
        <item name="android:textColor">@color/charcoal</item>
        <item name="chipCornerRadius">20dp</item>
        <item name="android:textSize">@dimen/text_sm</item>
        <item name="android:fontFamily">@font/nunito_bold</item>
    </style>
</resources>
