<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/gradient_background">

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        android:padding="32dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- Logo Circle -->
        <FrameLayout
            android:layout_width="@dimen/logo_size_large"
            android:layout_height="@dimen/logo_size_large"
            android:layout_gravity="center">
            <View
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@drawable/bg_circle_lavender"
                android:elevation="4dp"/>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:text="💊"
                android:textSize="42sp"
                android:elevation="8dp"/>
        </FrameLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="MediEase"
            android:textSize="44sp"
            android:fontFamily="@font/nunito"
            android:textStyle="bold"
            android:textColor="#3A2550"
            android:layout_marginTop="20dp"
            android:letterSpacing="-0.02"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Your Simple, Smart Medication Companion"
            android:textSize="16sp"
            android:fontFamily="@font/nunito"
            android:textColor="#6A4A8A"
            android:gravity="center"
            android:layout_marginTop="10dp"
            android:maxWidth="260dp"/>

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
