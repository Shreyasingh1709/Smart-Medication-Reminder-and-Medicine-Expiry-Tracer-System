<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/oat">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/lavender"
        android:orientation="vertical"
        android:paddingTop="@dimen/header_padding_top"
        android:paddingHorizontal="@dimen/header_padding_h"
        android:paddingBottom="20dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="@font/nunito_extrabold"
            android:text="@string/analysis"
            android:textColor="@color/charcoal"
            android:textSize="@dimen/text_h2" />
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="@font/nunito"
            android:text="@string/adherence_overview"
            android:textColor="@color/charcoal_light"
            android:textSize="@dimen/text_small"
            android:layout_marginTop="3dp" />

        <!-- Period selector tabs -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:background="@drawable/bg_toggle_bar"
            android:orientation="horizontal"
            android:padding="4dp"
            android:layout_marginTop="16dp">

            <Button
                android:id="@+id/btn_weekly"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:background="@drawable/bg_toggle_selected"
                android:fontFamily="@font/nunito_extrabold"
                android:text="@string/weekly_view"
                android:textColor="@color/charcoal"
                android:textSize="@dimen/text_body_sm"
                android:stateListAnimator="@null" />

            <Button
                android:id="@+id/btn_monthly"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:background="@null"
                android:fontFamily="@font/nunito_bold"
                android:text="@string/monthly_view"
                android:textColor="@color/charcoal_light"
                android:textSize="@dimen/text_body_sm"
                android:stateListAnimator="@null" />

            <Button
                android:id="@+id/btn_all_time"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:background="@null"
                android:fontFamily="@font/nunito_bold"
                android:text="@string/all_time_view"
                android:textColor="@color/charcoal_light"
                android:textSize="@dimen/text_body_sm"
                android:stateListAnimator="@null" />
        </LinearLayout>
    </LinearLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:overScrollMode="never">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingTop="18dp"
            android:paddingHorizontal="18dp"
            android:paddingBottom="@dimen/bottom_nav_padding_bottom">

            <!-- Stats row: 3 cards -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="14dp">

                <!-- Adherence rate (big) -->
                <androidx.cardview.widget.CardView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1.2"
                    android:layout_marginEnd="8dp"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="4dp"
                    app:cardBackgroundColor="@color/coral">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="16dp">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="🎯"
                            android:textSize="26sp" />
                        <TextView
                            android:id="@+id/tv_adherence_rate"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="@font/nunito_black"
                            android:textColor="@color/white"
                            android:textSize="32sp"
                            android:layout_marginTop="4dp"
                            android:text="80%" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/adherence_rate"
                            android:fontFamily="@font/nunito_semibold"
                            android:textColor="@color/white"
                            android:textSize="@dimen/text_xs"
                            android:alpha="0.85" />
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <!-- Taken card -->
                    <androidx.cardview.widget.CardView
                        android:layout_width="match_parent"
                        android:layout_height="0dp"
                        android:layout_weight="1"
                        android:layout_marginBottom="8dp"
                        app:cardCornerRadius="14dp"
                        app:cardElevation="3dp"
                        app:cardBackgroundColor="@color/white">
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:orientation="vertical"
                            android:padding="12dp">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="✅" android:textSize="18sp" />
                            <TextView
                                android:id="@+id/tv_total_taken"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:fontFamily="@font/nunito_black"
                                android:textColor="@color/green_dark"
                                android:textSize="@dimen/text_h4"
                                android:text="--" />
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="@string/total_taken"
                                android:fontFamily="@font/nunito_semibold"
                                android:textColor="@color/charcoal_light"
                                android:textSize="@dimen/text_xxs" />
                        </LinearLayout>
                    </androidx.cardview.widget.CardView>

                    <!-- Missed card -->
                    <androidx.cardview.widget.CardView
                        android:layout_width="match_parent"
                        android:layout_height="0dp"
                        android:layout_weight="1"
                        app:cardCornerRadius="14dp"
                        app:cardElevation="3dp"
                        app:cardBackgroundColor="@color/white">
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:orientation="vertical"
                            android:padding="12dp">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="⚠️" android:textSize="18sp" />
                            <TextView
                                android:id="@+id/tv_total_missed"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:fontFamily="@font/nunito_black"
                                android:textColor="@color/status_missed_text"
                                android:textSize="@dimen/text_h4"
                                android:text="--" />
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="@string/total_missed"
                                android:fontFamily="@font/nunito_semibold"
                                android:textColor="@color/charcoal_light"
                                android:textSize="@dimen/text_xxs" />
                        </LinearLayout>
                    </androidx.cardview.widget.CardView>

                </LinearLayout>
            </LinearLayout>

            <!-- Streak cards -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="14dp">
                <androidx.cardview.widget.CardView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginEnd="8dp"
                    app:cardCornerRadius="14dp"
                    app:cardElevation="3dp"
                    app:cardBackgroundColor="@color/white">
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:orientation="vertical" android:padding="14dp">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="🔥 Current Streak"
                            android:fontFamily="@font/nunito_bold"
                            android:textColor="@color/charcoal_light"
                            android:textSize="@dimen/text_small" />
                        <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:orientation="horizontal" android:gravity="center_vertical"
                            android:layout_marginTop="4dp">
                            <TextView
                                android:id="@+id/tv_streak"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:fontFamily="@font/nunito_black"
                                android:textColor="@color/coral"
                                android:textSize="28sp"
                                android:text="0" />
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text=" days"
                                android:fontFamily="@font/nunito_semibold"
                                android:textColor="@color/charcoal_light"
                                android:textSize="@dimen/text_caption" />
                        </LinearLayout>
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <androidx.cardview.widget.CardView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    app:cardCornerRadius="14dp"
                    app:cardElevation="3dp"
                    app:cardBackgroundColor="@color/white">
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:orientation="vertical" android:padding="14dp">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="⭐ Most Missed"
                            android:fontFamily="@font/nunito_bold"
                            android:textColor="@color/charcoal_light"
                            android:textSize="@dimen/text_small" />
                        <TextView
                            android:id="@+id/tv_most_missed"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="@font/nunito_extrabold"
                            android:textColor="@color/status_missed_text"
                            android:textSize="@dimen/text_body_sm"
                            android:layout_marginTop="4dp"
                            android:text="None" />
                    </LinearLayout>
                </androidx.cardview.widget.CardView>
            </LinearLayout>

            <!-- Bar chart: Weekly doses -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="14dp"
                app:cardCornerRadius="18dp"
                app:cardElevation="4dp"
                app:cardBackgroundColor="@color/white">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="18dp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/missed_doses_trend"
                        android:fontFamily="@font/nunito_extrabold"
                        android:textColor="@color/charcoal"
                        android:textSize="@dimen/text_body"
                        android:layout_marginBottom="12dp" />
                    <com.github.mikephil.charting.charts.BarChart
                        android:id="@+id/bar_chart"
                        android:layout_width="match_parent"
                        android:layout_height="@dimen/chart_height" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Adherence line chart -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="14dp"
                app:cardCornerRadius="18dp"
                app:cardElevation="4dp"
                app:cardBackgroundColor="@color/white">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="18dp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Daily Adherence %"
                        android:fontFamily="@font/nunito_extrabold"
                        android:textColor="@color/charcoal"
                        android:textSize="@dimen/text_body"
                        android:layout_marginBottom="12dp" />
                    <com.github.mikephil.charting.charts.LineChart
                        android:id="@+id/line_chart"
                        android:layout_width="match_parent"
                        android:layout_height="@dimen/chart_height" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Improvement tip -->
            <LinearLayout
                android:id="@+id/card_tip"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_tip_card"
                android:orientation="horizontal"
                android:padding="14dp"
                android:gravity="center_vertical">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="💡"
                    android:textSize="24sp"
                    android:layout_marginEnd="10dp" />
                <TextView
                    android:id="@+id/tv_tip"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:fontFamily="@font/nunito_semibold"
                    android:textColor="@color/charcoal"
                    android:textSize="@dimen/text_small"
                    android:lineSpacingMultiplier="1.4"
                    android:text="@string/tip_consistency" />
            </LinearLayout>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</LinearLayout>
