<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="match_parent"
    android:orientation="vertical" android:background="@color/oat">

    <!-- Setup Header -->
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="vertical" android:background="@color/lavender"
        android:paddingTop="48dp" android:paddingBottom="24dp" android:paddingHorizontal="22dp">

        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:gravity="center_vertical"
            android:layout_marginBottom="16dp">
            <Button android:id="@+id/btn_back" android:layout_width="40dp" android:layout_height="40dp"
                android:text="←" android:textSize="20sp" android:background="@null"
                android:visibility="invisible" android:contentDescription="Go back"/>
            <TextView android:id="@+id/tv_step_label" android:layout_width="0dp"
                android:layout_height="wrap_content" android:layout_weight="1"
                android:text="Step 1 of 4" android:textSize="13sp" android:fontFamily="@font/nunito"
                android:textStyle="bold" android:textColor="@color/charcoal_light" android:gravity="center"/>
            <View android:layout_width="40dp" android:layout_height="40dp"/>
        </LinearLayout>

        <!-- Progress dots -->
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:gravity="center" android:layout_marginBottom="18dp">
            <View android:id="@+id/dot1" android:layout_width="28dp" android:layout_height="8dp"
                android:background="#F4A58D" android:layout_marginHorizontal="3dp"/>
            <View android:id="@+id/dot2" android:layout_width="8dp" android:layout_height="8dp"
                android:background="@color/oat_dark" android:layout_marginHorizontal="3dp"/>
            <View android:id="@+id/dot3" android:layout_width="8dp" android:layout_height="8dp"
                android:background="@color/oat_dark" android:layout_marginHorizontal="3dp"/>
            <View android:id="@+id/dot4" android:layout_width="8dp" android:layout_height="8dp"
                android:background="@color/oat_dark" android:layout_marginHorizontal="3dp"/>
        </LinearLayout>

        <!-- Icon, Title, Subtitle -->
        <FrameLayout android:layout_width="60dp" android:layout_height="60dp"
            android:layout_gravity="center">
            <View android:layout_width="match_parent" android:layout_height="match_parent"
                android:background="@drawable/bg_circle_coral_light"/>
            <TextView android:id="@+id/tv_step_icon" android:layout_width="wrap_content"
                android:layout_height="wrap_content" android:layout_gravity="center"
                android:text="🙋" android:textSize="28sp"/>
        </FrameLayout>
        <TextView android:id="@+id/tv_title" android:layout_width="match_parent"
            android:layout_height="wrap_content" android:text="What's your name?"
            android:textSize="22sp" android:fontFamily="@font/nunito" android:textStyle="bold"
            android:textColor="@color/charcoal" android:gravity="center" android:layout_marginTop="10dp"/>
        <TextView android:id="@+id/tv_subtitle" android:layout_width="match_parent"
            android:layout_height="wrap_content" android:text="This helps us personalise your experience"
            android:textSize="13sp" android:textColor="@color/charcoal_light"
            android:gravity="center" android:layout_marginTop="5dp"/>
    </LinearLayout>

    <androidx.core.widget.NestedScrollView android:layout_width="match_parent"
        android:layout_height="0dp" android:layout_weight="1">
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="vertical" android:padding="20dp">

            <!-- Step 1: Name -->
            <LinearLayout android:id="@+id/panel_step1" android:layout_width="match_parent"
                android:layout_height="wrap_content" android:orientation="vertical">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Full Name" android:textSize="16sp" android:fontFamily="@font/nunito"
                    android:textStyle="bold" android:textColor="@color/charcoal" android:layout_marginBottom="10dp"/>
                <LinearLayout android:layout_width="match_parent" android:layout_height="@dimen/field_height"
                    android:background="@drawable/bg_field" android:gravity="center_vertical"
                    android:paddingHorizontal="16dp" android:layout_marginBottom="14dp">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="🙋" android:textSize="20sp"/>
                    <EditText android:id="@+id/et_name" android:layout_width="0dp"
                        android:layout_height="match_parent" android:layout_weight="1"
                        android:background="@null" android:hint="e.g. Maria Johnson"
                        android:textSize="17sp" android:fontFamily="@font/nunito"
                        android:paddingStart="10dp" android:inputType="textPersonName"
                        android:textColor="@android:color/black"
                        android:textColorHint="@color/charcoal_light"/>
                </LinearLayout>
            </LinearLayout>

            <!-- Step 2: Age (replaces DOB) -->
            <LinearLayout android:id="@+id/panel_step2" android:layout_width="match_parent"
                android:layout_height="wrap_content" android:orientation="vertical" android:visibility="gone">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Enter your age" android:textSize="16sp" android:fontFamily="@font/nunito"
                    android:textStyle="bold" android:textColor="@color/charcoal" android:layout_marginBottom="10dp"/>
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:gravity="center_vertical" android:layout_marginBottom="12dp">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="🎂" android:textSize="28sp" android:layout_marginEnd="12dp"/>
                    <EditText android:id="@+id/et_age" android:layout_width="0dp"
                        android:layout_height="48dp" android:layout_weight="1"
                        android:background="@drawable/bg_field" android:hint="Enter your age"
                        android:textSize="16sp" android:fontFamily="@font/nunito"
                        android:inputType="number" android:textColor="@android:color/black"
                        android:textColorHint="@color/charcoal_light"/>
                </LinearLayout>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Or select your age range:" android:textSize="14sp" android:fontFamily="@font/nunito"
                    android:textColor="@color/charcoal_light" android:layout_marginBottom="6dp"/>
                <Spinner android:id="@+id/spinner_age_range" android:layout_width="match_parent"
                    android:layout_height="48dp" android:background="@drawable/bg_field"
                    android:entries="@array/age_ranges" android:paddingHorizontal="12dp"
                    android:spinnerMode="dropdown"/>
            </LinearLayout>

            <!-- Step 3: Sleep -->
            <LinearLayout android:id="@+id/panel_step3" android:layout_width="match_parent"
                android:layout_height="wrap_content" android:orientation="vertical" android:visibility="gone">
                <LinearLayout android:id="@+id/card_wake_time" android:layout_width="match_parent"
                    android:layout_height="72dp" android:background="@drawable/bg_picker_row"
                    android:gravity="center_vertical" android:paddingHorizontal="18dp"
                    android:layout_marginBottom="12dp">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="☀️" android:textSize="28sp" android:layout_marginEnd="12dp"/>
                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Wake Up Time" android:textSize="12sp" android:textColor="@color/charcoal_light"/>
                        <TextView android:id="@+id/tv_wake_time" android:layout_width="wrap_content"
                            android:layout_height="wrap_content" android:text="Tap to set"
                            android:textSize="16sp" android:fontFamily="@font/nunito" android:textStyle="bold"
                            android:textColor="@color/charcoal"/>
                    </LinearLayout>
                </LinearLayout>
                <LinearLayout android:id="@+id/card_bed_time" android:layout_width="match_parent"
                    android:layout_height="72dp" android:background="@drawable/bg_picker_row"
                    android:gravity="center_vertical" android:paddingHorizontal="18dp"
                    android:layout_marginBottom="12dp">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="🌙" android:textSize="28sp" android:layout_marginEnd="12dp"/>
                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Bed Time" android:textSize="12sp" android:textColor="@color/charcoal_light"/>
                        <TextView android:id="@+id/tv_bed_time" android:layout_width="wrap_content"
                            android:layout_height="wrap_content" android:text="Tap to set"
                            android:textSize="16sp" android:fontFamily="@font/nunito" android:textStyle="bold"
                            android:textColor="@color/charcoal"/>
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>

            <!-- Step 4: Meals -->
            <LinearLayout android:id="@+id/panel_step4" android:layout_width="match_parent"
                android:layout_height="wrap_content" android:orientation="vertical" android:visibility="gone">
                <LinearLayout android:id="@+id/card_breakfast_time" android:layout_width="match_parent"
                    android:layout_height="72dp" android:background="@drawable/bg_picker_row"
                    android:gravity="center_vertical" android:paddingHorizontal="18dp"
                    android:layout_marginBottom="12dp">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="🌅" android:textSize="28sp" android:layout_marginEnd="12dp"/>
                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Breakfast" android:textSize="12sp" android:textColor="@color/charcoal_light"/>
                        <TextView android:id="@+id/tv_breakfast_time" android:layout_width="wrap_content"
                            android:layout_height="wrap_content" android:text="Tap to set"
                            android:textSize="16sp" android:fontFamily="@font/nunito" android:textStyle="bold"
                            android:textColor="@color/charcoal"/>
                    </LinearLayout>
                </LinearLayout>
                <LinearLayout android:id="@+id/card_lunch_time" android:layout_width="match_parent"
                    android:layout_height="72dp" android:background="@drawable/bg_picker_row"
                    android:gravity="center_vertical" android:paddingHorizontal="18dp"
                    android:layout_marginBottom="12dp">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="☀️" android:textSize="28sp" android:layout_marginEnd="12dp"/>
                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Lunch" android:textSize="12sp" android:textColor="@color/charcoal_light"/>
                        <TextView android:id="@+id/tv_lunch_time" android:layout_width="wrap_content"
                            android:layout_height="wrap_content" android:text="Tap to set"
                            android:textSize="16sp" android:fontFamily="@font/nunito" android:textStyle="bold"
                            android:textColor="@color/charcoal"/>
                    </LinearLayout>
                </LinearLayout>
                <LinearLayout android:id="@+id/card_dinner_time" android:layout_width="match_parent"
                    android:layout_height="72dp" android:background="@drawable/bg_picker_row"
                    android:gravity="center_vertical" android:paddingHorizontal="18dp"
                    android:layout_marginBottom="12dp">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="🍽️" android:textSize="28sp" android:layout_marginEnd="12dp"/>
                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Dinner" android:textSize="12sp" android:textColor="@color/charcoal_light"/>
                        <TextView android:id="@+id/tv_dinner_time" android:layout_width="wrap_content"
                            android:layout_height="wrap_content" android:text="Tap to set"
                            android:textSize="16sp" android:fontFamily="@font/nunito" android:textStyle="bold"
                            android:textColor="@color/charcoal"/>
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <!-- Next Button -->
    <Button android:id="@+id/btn_next"
        android:layout_width="match_parent" android:layout_height="56dp"
        android:layout_marginHorizontal="20dp" android:layout_marginBottom="24dp"
        android:text="Next →" android:background="@drawable/bg_btn_coral"
        android:textColor="@color/white" android:textSize="17sp"
        android:fontFamily="@font/nunito" android:textStyle="bold" android:stateListAnimator="@null"/>

</LinearLayout>
