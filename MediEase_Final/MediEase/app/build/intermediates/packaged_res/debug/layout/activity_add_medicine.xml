<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent" android:layout_height="match_parent"
    android:orientation="vertical" android:background="@color/oat">

    <!-- Header -->
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:background="@color/lavender" android:paddingTop="48dp" android:paddingBottom="20dp"
        android:paddingHorizontal="16dp" android:gravity="center_vertical">
        <Button android:id="@+id/btn_back" android:layout_width="56dp" android:layout_height="56dp"
            android:text="←" android:background="@null" android:textSize="32sp"
            android:textColor="@color/charcoal" android:stateListAnimator="@null"
            android:gravity="center" android:padding="0dp"
            android:contentDescription="@string/cd_back_button"/>
        <TextView android:id="@+id/tv_title" android:layout_width="0dp"
            android:layout_height="wrap_content" android:layout_weight="1"
            android:text="Add Medicine" android:textSize="22sp" android:fontFamily="@font/nunito"
            android:textStyle="bold" android:textColor="@color/charcoal" android:paddingStart="4dp"/>
    </LinearLayout>

    <androidx.core.widget.NestedScrollView android:layout_width="match_parent"
        android:layout_height="0dp" android:layout_weight="1">
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="vertical" android:padding="20dp">

            <!-- Medicine Image -->
            <androidx.cardview.widget.CardView android:layout_width="match_parent"
                android:layout_height="180dp" app:cardCornerRadius="16dp"
                app:cardElevation="3dp" app:cardBackgroundColor="@color/white"
                android:layout_marginBottom="18dp">
                <FrameLayout android:layout_width="match_parent" android:layout_height="match_parent">
                    <ImageView android:id="@+id/iv_medicine_image" android:layout_width="match_parent"
                        android:layout_height="match_parent" android:scaleType="centerInside"
                        android:visibility="gone"
                        android:contentDescription="@string/cd_medicine_image"/>
                    <LinearLayout android:id="@+id/layout_image_placeholder"
                        android:layout_width="match_parent" android:layout_height="match_parent"
                        android:orientation="vertical" android:gravity="center">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="📸" android:textSize="48sp"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Upload Image" android:textSize="14sp"
                            android:fontFamily="@font/nunito" android:textColor="@color/charcoal_light"/>
                    </LinearLayout>
                    <TextView android:id="@+id/tv_queue_status" android:layout_width="wrap_content"
                        android:layout_height="wrap_content" android:layout_gravity="top|end"
                        android:layout_margin="12dp" android:paddingHorizontal="8dp"
                        android:paddingVertical="4dp" android:background="@drawable/bg_tag_lavender"
                        android:textColor="@color/lavender_deeper" android:textSize="12sp"
                        android:textStyle="bold" android:visibility="gone" android:text="1 of 1"/>
                </FrameLayout>
            </androidx.cardview.widget.CardView>

            <!-- Image Buttons -->
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:layout_marginBottom="20dp">
                <Button android:id="@+id/btn_camera" android:layout_width="0dp"
                    android:layout_height="48dp" android:layout_weight="1"
                    android:text="📷 Camera" android:background="@drawable/bg_btn_outline"
                    android:textColor="@color/charcoal" android:textSize="14sp"
                    android:fontFamily="@font/nunito" android:textStyle="bold"
                    android:stateListAnimator="@null" android:layout_marginEnd="8dp"/>
                <Button android:id="@+id/btn_gallery" android:layout_width="0dp"
                    android:layout_height="48dp" android:layout_weight="1"
                    android:text="🖼️ Gallery" android:background="@drawable/bg_btn_outline"
                    android:textColor="@color/charcoal" android:textSize="14sp"
                    android:fontFamily="@font/nunito" android:textStyle="bold"
                    android:stateListAnimator="@null" android:layout_marginStart="8dp"/>
            </LinearLayout>

            <!-- Base Schedule Info -->
            <HorizontalScrollView android:layout_width="match_parent" android:layout_height="wrap_content"
                android:scrollbars="none" android:layout_marginBottom="16dp">
                <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:orientation="horizontal">
                    <com.google.android.material.chip.Chip android:id="@+id/chip_base_breakfast"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Breakfast: --:--" android:layout_marginEnd="8dp"
                        app:chipBackgroundColor="@color/white" app:chipStrokeWidth="1dp" app:chipStrokeColor="@color/lavender"/>
                    <com.google.android.material.chip.Chip android:id="@+id/chip_base_lunch"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Lunch: --:--" android:layout_marginEnd="8dp"
                        app:chipBackgroundColor="@color/white" app:chipStrokeWidth="1dp" app:chipStrokeColor="@color/lavender"/>
                    <com.google.android.material.chip.Chip android:id="@+id/chip_base_dinner"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Dinner: --:--" android:layout_marginEnd="8dp"
                        app:chipBackgroundColor="@color/white" app:chipStrokeWidth="1dp" app:chipStrokeColor="@color/lavender"/>
                </LinearLayout>
            </HorizontalScrollView>

            <!-- Medicine Name -->
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Medicine Name *" android:textSize="15sp" android:fontFamily="@font/nunito"
                android:textStyle="bold" android:textColor="@color/charcoal" android:layout_marginBottom="8dp"/>
            <LinearLayout android:layout_width="match_parent" android:layout_height="52dp"
                android:background="@drawable/bg_field" android:gravity="center_vertical"
                android:paddingHorizontal="16dp" android:layout_marginBottom="16dp">
                <EditText android:id="@+id/et_medicine_name" android:layout_width="match_parent"
                    android:layout_height="match_parent" android:background="@null"
                    android:hint="Name" android:textSize="17sp"
                    android:fontFamily="@font/nunito" android:inputType="textCapWords"
                    android:textColor="@android:color/black"/>
            </LinearLayout>

            <!-- Dosage -->
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Dosage" android:textSize="15sp" android:fontFamily="@font/nunito"
                android:textStyle="bold" android:textColor="@color/charcoal" android:layout_marginBottom="8dp"/>
            <LinearLayout android:layout_width="match_parent" android:layout_height="52dp"
                android:background="@drawable/bg_field" android:gravity="center_vertical"
                android:paddingHorizontal="16dp" android:layout_marginBottom="16dp">
                <EditText android:id="@+id/et_dosage" android:layout_width="match_parent"
                    android:layout_height="match_parent" android:background="@null"
                    android:hint="e.g. 500mg" android:textSize="17sp" android:fontFamily="@font/nunito"
                    android:textColor="@android:color/black"/>
            </LinearLayout>

            <!-- Medicine Type -->
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Medicine Type" android:textSize="15sp" android:fontFamily="@font/nunito"
                android:textStyle="bold" android:textColor="@color/charcoal" android:layout_marginBottom="8dp"/>
            <com.google.android.material.chip.ChipGroup android:id="@+id/cg_type"
                android:layout_width="match_parent"
                android:layout_height="wrap_content" android:layout_marginBottom="16dp"
                app:singleSelection="true">
                <com.google.android.material.chip.Chip android:id="@+id/chip_tablet"
                    android:layout_width="wrap_content" android:layout_height="48dp"
                    android:text="💊 Tablet" style="@style/Widget.MaterialComponents.Chip.Choice"
                    android:checked="true"/>
                <com.google.android.material.chip.Chip android:id="@+id/chip_capsule"
                    android:layout_width="wrap_content" android:layout_height="48dp"
                    android:text="💉 Capsule" style="@style/Widget.MaterialComponents.Chip.Choice"/>
                <com.google.android.material.chip.Chip android:id="@+id/chip_syrup"
                    android:layout_width="wrap_content" android:layout_height="48dp"
                    android:text="🍶 Syrup" style="@style/Widget.MaterialComponents.Chip.Choice"/>
                <com.google.android.material.chip.Chip android:id="@+id/chip_drops"
                    android:layout_width="wrap_content" android:layout_height="48dp"
                    android:text="💧 Drops" style="@style/Widget.MaterialComponents.Chip.Choice"/>
            </com.google.android.material.chip.ChipGroup>

            <!-- Meal Timing -->
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="When to Take" android:textSize="15sp" android:fontFamily="@font/nunito"
                android:textStyle="bold" android:textColor="@color/charcoal" android:layout_marginBottom="8dp"/>
            <com.google.android.material.chip.ChipGroup android:id="@+id/cg_meal"
                android:layout_width="match_parent"
                android:layout_height="wrap_content" android:layout_marginBottom="16dp"
                app:singleSelection="true">
                <com.google.android.material.chip.Chip android:id="@+id/chip_before"
                    android:layout_width="wrap_content" android:layout_height="48dp"
                    android:text="Before Meal" style="@style/Widget.MaterialComponents.Chip.Choice"/>
                <com.google.android.material.chip.Chip android:id="@+id/chip_after"
                    android:layout_width="wrap_content" android:layout_height="48dp"
                    android:text="After Meal" style="@style/Widget.MaterialComponents.Chip.Choice"/>
                <com.google.android.material.chip.Chip android:id="@+id/chip_with"
                    android:layout_width="wrap_content" android:layout_height="48dp"
                    android:text="With Meal" style="@style/Widget.MaterialComponents.Chip.Choice"/>
                <com.google.android.material.chip.Chip android:id="@+id/chip_anytime"
                    android:layout_width="wrap_content" android:layout_height="48dp"
                    android:text="Any Time" style="@style/Widget.MaterialComponents.Chip.Choice"
                    android:checked="true"/>
            </com.google.android.material.chip.ChipGroup>

            <!-- Repeat Days -->
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Repeat Days" android:textSize="15sp" android:fontFamily="@font/nunito"
                android:textStyle="bold" android:textColor="@color/charcoal" android:layout_marginBottom="8dp"/>
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:layout_marginBottom="16dp">
                <com.google.android.material.chip.Chip android:id="@+id/chip_mon"
                    android:layout_width="0dp" android:layout_height="44dp" android:layout_weight="1"
                    android:text="M" style="@style/Widget.MaterialComponents.Chip.Choice" android:checked="true"/>
                <com.google.android.material.chip.Chip android:id="@+id/chip_tue"
                    android:layout_width="0dp" android:layout_height="44dp" android:layout_weight="1"
                    android:text="T" style="@style/Widget.MaterialComponents.Chip.Choice" android:checked="true"/>
                <com.google.android.material.chip.Chip android:id="@+id/chip_wed"
                    android:layout_width="0dp" android:layout_height="44dp" android:layout_weight="1"
                    android:text="W" style="@style/Widget.MaterialComponents.Chip.Choice" android:checked="true"/>
                <com.google.android.material.chip.Chip android:id="@+id/chip_thu"
                    android:layout_width="0dp" android:layout_height="44dp" android:layout_weight="1"
                    android:text="T" style="@style/Widget.MaterialComponents.Chip.Choice" android:checked="true"/>
                <com.google.android.material.chip.Chip android:id="@+id/chip_fri"
                    android:layout_width="0dp" android:layout_height="44dp" android:layout_weight="1"
                    android:text="F" style="@style/Widget.MaterialComponents.Chip.Choice" android:checked="true"/>
                <com.google.android.material.chip.Chip android:id="@+id/chip_sat"
                    android:layout_width="0dp" android:layout_height="44dp" android:layout_weight="1"
                    android:text="S" style="@style/Widget.MaterialComponents.Chip.Choice" android:checked="true"/>
                <com.google.android.material.chip.Chip android:id="@+id/chip_sun"
                    android:layout_width="0dp" android:layout_height="44dp" android:layout_weight="1"
                    android:text="S" style="@style/Widget.MaterialComponents.Chip.Choice" android:checked="true"/>
            </LinearLayout>

            <!-- Reminder Times -->
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Reminder Times *" android:textSize="15sp" android:fontFamily="@font/nunito"
                android:textStyle="bold" android:textColor="@color/charcoal" android:layout_marginBottom="8dp"/>
            <com.google.android.material.chip.ChipGroup android:id="@+id/time_chips_container"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"/>
            <Button android:id="@+id/btn_add_time"
                android:layout_width="match_parent" android:layout_height="52dp"
                android:text="+ Add Reminder Time" android:background="@drawable/bg_btn_outline"
                android:textColor="@color/charcoal" android:textSize="15sp"
                android:fontFamily="@font/nunito" android:textStyle="bold"
                android:stateListAnimator="@null" android:layout_marginBottom="16dp"/>

            <!-- Expiry Date -->
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Expiry Date *" android:textSize="15sp" android:fontFamily="@font/nunito"
                android:textStyle="bold" android:textColor="@color/charcoal" android:layout_marginBottom="8dp"/>
            <LinearLayout android:id="@+id/card_expiry" android:layout_width="match_parent"
                android:layout_height="60dp" android:background="@drawable/bg_picker_row"
                android:gravity="center_vertical" android:paddingHorizontal="18dp"
                android:layout_marginBottom="24dp">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="📅" android:textSize="22sp" android:layout_marginEnd="12dp"/>
                <TextView android:id="@+id/tv_expiry_date" android:layout_width="0dp"
                    android:layout_height="wrap_content" android:layout_weight="1"
                    android:text="Tap to set expiry date" android:textSize="16sp"
                    android:fontFamily="@font/nunito" android:textColor="@color/charcoal_light"/>
            </LinearLayout>

            <!-- Notes -->
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Notes / Duration" android:textSize="15sp" android:fontFamily="@font/nunito"
                android:textStyle="bold" android:textColor="@color/charcoal" android:layout_marginBottom="8dp"/>
            <LinearLayout android:layout_width="match_parent" android:layout_height="100dp"
                android:background="@drawable/bg_field" android:paddingHorizontal="16dp"
                android:paddingVertical="12dp" android:layout_marginBottom="24dp">
                <EditText android:id="@+id/et_notes" android:layout_width="match_parent"
                    android:layout_height="match_parent" android:background="@null"
                    android:hint="Special instructions or duration..." android:textSize="16sp"
                    android:fontFamily="@font/nunito" android:gravity="top"
                    android:inputType="textMultiLine" android:lines="3"
                    android:textColor="@android:color/black"/>
            </LinearLayout>

            <!-- Actions -->
            <Button android:id="@+id/btn_save_and_next"
                android:layout_width="match_parent" android:layout_height="56dp"
                android:text="➕ Save &amp; Next Medicine" android:background="@drawable/bg_btn_outline"
                android:textColor="@color/charcoal" android:textSize="16sp"
                android:fontFamily="@font/nunito" android:textStyle="bold"
                android:stateListAnimator="@null" android:layout_marginBottom="12dp"
                android:visibility="gone"/>

            <Button android:id="@+id/btn_save"
                android:layout_width="match_parent" android:layout_height="56dp"
                android:text="💾 Save &amp; Finish" android:background="@drawable/bg_btn_coral"
                android:textColor="@color/white" android:textSize="18sp"
                android:fontFamily="@font/nunito" android:textStyle="bold"
                android:stateListAnimator="@null"/>
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>
</LinearLayout>
