<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="match_parent"
    android:orientation="vertical" android:background="@color/oat">
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:background="@color/lavender" android:paddingTop="48dp"
        android:paddingBottom="20dp" android:paddingHorizontal="22dp">
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="🔔 Reminders" android:textSize="26sp" android:fontFamily="@font/nunito"
            android:textStyle="bold" android:textColor="@color/charcoal"/>
    </LinearLayout>
    <TextView android:id="@+id/tv_no_reminders" android:layout_width="match_parent"
        android:layout_height="wrap_content" android:text="No reminders set yet.\nAdd a medicine to schedule reminders."
        android:gravity="center" android:padding="48dp" android:textSize="16sp"
        android:textColor="@color/charcoal_light" android:visibility="gone"/>
    <androidx.recyclerview.widget.RecyclerView android:id="@+id/rv_reminders"
        android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="1"
        android:padding="18dp" android:clipToPadding="false"/>
</LinearLayout>
