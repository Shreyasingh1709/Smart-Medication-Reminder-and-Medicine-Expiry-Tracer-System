<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="match_parent"
    android:orientation="vertical" android:background="@color/oat">

    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:background="@color/lavender" android:paddingTop="48dp"
        android:paddingBottom="20dp" android:paddingHorizontal="22dp">
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="📊 Analysis" android:textSize="26sp" android:fontFamily="@font/nunito"
            android:textStyle="bold" android:textColor="@color/charcoal"/>
    </LinearLayout>

    <ProgressBar android:id="@+id/progress_bar" android:layout_width="wrap_content"
        android:layout_height="wrap_content" android:layout_gravity="center"
        android:visibility="gone"/>

    <androidx.core.widget.NestedScrollView android:layout_width="match_parent"
        android:layout_height="0dp" android:layout_weight="1">
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="vertical" android:padding="18dp">

            <!-- Period tabs -->
            <LinearLayout android:layout_width="match_parent" android:layout_height="50dp"
                android:background="@drawable/bg_toggle_bar" android:padding="4dp"
                android:layout_marginBottom="18dp">
                <Button android:id="@+id/btn_weekly" android:layout_width="0dp"
                    android:layout_height="match_parent" android:layout_weight="1"
                    android:text="This Week" android:background="@drawable/bg_toggle_selected"
                    android:textColor="@color/charcoal" android:textSize="14sp"
                    android:fontFamily="@font/nunito" android:textStyle="bold"
                    android:stateListAnimator="@null"/>
                <Button android:id="@+id/btn_monthly" android:layout_width="0dp"
                    android:layout_height="match_parent" android:layout_weight="1"
                    android:text="This Month" android:background="@null"
                    android:textColor="@color/charcoal_light" android:textSize="14sp"
                    android:fontFamily="@font/nunito" android:textStyle="bold"
                    android:stateListAnimator="@null"/>
            </LinearLayout>

            <!-- Adherence Rate Card -->
            <androidx.cardview.widget.CardView android:layout_width="match_parent"
                android:layout_height="wrap_content"
                xmlns:app="http://schemas.android.com/apk/res-auto"
                app:cardCornerRadius="20dp" app:cardElevation="4dp"
                app:cardBackgroundColor="@color/white" android:layout_marginBottom="14dp">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="vertical" android:padding="20dp">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Overall Adherence" android:textSize="16sp"
                        android:fontFamily="@font/nunito" android:textStyle="bold"
                        android:textColor="@color/charcoal" android:layout_marginBottom="12dp"/>
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:orientation="horizontal" android:gravity="center_vertical"
                        android:layout_marginBottom="12dp">
                        <TextView android:id="@+id/tv_adherence_percent" android:layout_width="0dp"
                            android:layout_height="wrap_content" android:layout_weight="1"
                            android:text="0%" android:textSize="48sp" android:fontFamily="@font/nunito"
                            android:textStyle="bold" android:textColor="@color/lavender_deeper"/>
                        <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:orientation="vertical">
                            <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:gravity="center_vertical" android:layout_marginBottom="8dp">
                                <View android:layout_width="12dp" android:layout_height="12dp"
                                    android:background="@drawable/bg_circle_lavender" android:layout_marginEnd="6dp"/>
                                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                    android:text="Taken: " android:textSize="13sp"
                                    android:textColor="@color/charcoal_light"/>
                                <TextView android:id="@+id/tv_taken_count" android:layout_width="wrap_content"
                                    android:layout_height="wrap_content" android:text="0"
                                    android:textSize="13sp" android:fontFamily="@font/nunito"
                                    android:textStyle="bold" android:textColor="@color/status_taken_text"/>
                            </LinearLayout>
                            <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:gravity="center_vertical" android:layout_marginBottom="8dp">
                                <View android:layout_width="12dp" android:layout_height="12dp"
                                    android:background="@drawable/bg_circle_coral_light" android:layout_marginEnd="6dp"/>
                                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                    android:text="Missed: " android:textSize="13sp"
                                    android:textColor="@color/charcoal_light"/>
                                <TextView android:id="@+id/tv_missed_count" android:layout_width="wrap_content"
                                    android:layout_height="wrap_content" android:text="0"
                                    android:textSize="13sp" android:fontFamily="@font/nunito"
                                    android:textStyle="bold" android:textColor="@color/status_missed_text"/>
                            </LinearLayout>
                            <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:gravity="center_vertical">
                                <View android:layout_width="12dp" android:layout_height="12dp"
                                    android:background="@drawable/bg_circle_white" android:layout_marginEnd="6dp"/>
                                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                    android:text="Total: " android:textSize="13sp"
                                    android:textColor="@color/charcoal_light"/>
                                <TextView android:id="@+id/tv_total_scheduled" android:layout_width="wrap_content"
                                    android:layout_height="wrap_content" android:text="0"
                                    android:textSize="13sp" android:fontFamily="@font/nunito"
                                    android:textStyle="bold" android:textColor="@color/charcoal"/>
                            </LinearLayout>
                        </LinearLayout>
                    </LinearLayout>
                    <ProgressBar android:id="@+id/progress_adherence"
                        style="?android:attr/progressBarStyleHorizontal"
                        android:layout_width="match_parent" android:layout_height="12dp"
                        android:max="100" android:progress="0"
                        android:progressTint="@color/lavender_deep"
                        android:progressBackgroundTint="@color/oat_dark"/>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Tip Card -->
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:background="@color/lavender" android:padding="14dp"
                android:orientation="horizontal" android:layout_marginBottom="18dp">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="💡" android:textSize="22sp" android:layout_marginEnd="10dp"/>
                <TextView android:id="@+id/tv_tip" android:layout_width="0dp"
                    android:layout_height="wrap_content" android:layout_weight="1"
                    android:text="Keep taking your medicines as scheduled!"
                    android:textSize="14sp" android:textColor="@color/charcoal"/>
            </LinearLayout>

            <!-- Bar Chart -->
            <androidx.cardview.widget.CardView android:layout_width="match_parent"
                android:layout_height="wrap_content"
                xmlns:app="http://schemas.android.com/apk/res-auto"
                app:cardCornerRadius="20dp" app:cardElevation="4dp"
                app:cardBackgroundColor="@color/white" android:layout_marginBottom="14dp">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="vertical" android:padding="16dp">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Daily Breakdown" android:textSize="16sp"
                        android:fontFamily="@font/nunito" android:textStyle="bold"
                        android:textColor="@color/charcoal" android:layout_marginBottom="12dp"/>
                    <com.github.mikephil.charting.charts.BarChart
                        android:id="@+id/bar_chart"
                        android:layout_width="match_parent" android:layout_height="220dp"/>
                </LinearLayout>
            </androidx.cardview.widget.CardView>
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>
</LinearLayout>
