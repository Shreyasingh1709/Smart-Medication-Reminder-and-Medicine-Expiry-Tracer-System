<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent" android:layout_height="match_parent"
    android:orientation="vertical" android:background="@color/oat">

    <!-- Header -->
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:background="@color/lavender" android:paddingTop="48dp" android:paddingBottom="28dp"
        android:paddingHorizontal="22dp" android:orientation="vertical" android:gravity="center">
        <FrameLayout android:layout_width="84dp" android:layout_height="84dp">
            <View android:layout_width="match_parent" android:layout_height="match_parent"
                android:background="@drawable/bg_circle_white"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:layout_gravity="center" android:text="👤" android:textSize="42sp"/>
        </FrameLayout>
        <TextView android:id="@+id/tv_user_name" android:layout_width="wrap_content"
            android:layout_height="wrap_content" android:text="Your Name" android:textSize="22sp"
            android:fontFamily="@font/nunito" android:textStyle="bold" android:textColor="@color/charcoal"
            android:layout_marginTop="8dp"/>
        <TextView android:id="@+id/tv_user_email" android:layout_width="wrap_content"
            android:layout_height="wrap_content" android:textSize="13sp"
            android:textColor="@color/charcoal_light" android:layout_marginTop="3dp"/>
        <TextView android:id="@+id/tv_user_badge" android:layout_width="wrap_content"
            android:layout_height="wrap_content" android:text="Patient" android:textSize="13sp"
            android:fontFamily="@font/nunito" android:textStyle="bold" android:textColor="@color/white"
            android:background="@drawable/bg_btn_coral" android:paddingHorizontal="18dp"
            android:paddingVertical="4dp" android:layout_marginTop="8dp"/>
    </LinearLayout>

    <androidx.core.widget.NestedScrollView android:layout_width="match_parent"
        android:layout_height="0dp" android:layout_weight="1">
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="vertical" android:padding="18dp">

            <!-- Schedule Card -->
            <androidx.cardview.widget.CardView android:layout_width="match_parent"
                android:layout_height="wrap_content" app:cardCornerRadius="18dp"
                app:cardElevation="4dp" app:cardBackgroundColor="@color/white"
                android:layout_marginBottom="14dp">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="vertical" android:padding="18dp">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Daily Schedule" android:textSize="16sp" android:fontFamily="@font/nunito"
                        android:textStyle="bold" android:textColor="@color/charcoal" android:layout_marginBottom="12dp"/>
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:orientation="horizontal">
                        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                            android:layout_weight="1" android:orientation="vertical"
                            android:background="@color/lavender" android:padding="12dp" android:layout_marginEnd="4dp">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="☀️" android:textSize="18sp"/>
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="WAKE UP" android:textSize="11sp" android:textStyle="bold"
                                android:textColor="@color/charcoal_light" android:layout_marginTop="4dp"/>
                            <TextView android:id="@+id/tv_wake_time" android:layout_width="wrap_content"
                                android:layout_height="wrap_content" android:text="07:00 AM"
                                android:textSize="16sp" android:fontFamily="@font/nunito" android:textStyle="bold"
                                android:textColor="@color/charcoal"/>
                        </LinearLayout>
                        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                            android:layout_weight="1" android:orientation="vertical"
                            android:background="@color/lavender" android:padding="12dp" android:layout_marginEnd="4dp">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="🌙" android:textSize="18sp"/>
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="BED TIME" android:textSize="11sp" android:textStyle="bold"
                                android:textColor="@color/charcoal_light" android:layout_marginTop="4dp"/>
                            <TextView android:id="@+id/tv_bed_time" android:layout_width="wrap_content"
                                android:layout_height="wrap_content" android:text="10:00 PM"
                                android:textSize="16sp" android:fontFamily="@font/nunito" android:textStyle="bold"
                                android:textColor="@color/charcoal"/>
                        </LinearLayout>
                        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                            android:layout_weight="1" android:orientation="vertical"
                            android:background="@color/lavender" android:padding="12dp">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="🍽️" android:textSize="18sp"/>
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="BREAKFAST" android:textSize="11sp" android:textStyle="bold"
                                android:textColor="@color/charcoal_light" android:layout_marginTop="4dp"/>
                            <TextView android:id="@+id/tv_breakfast_time" android:layout_width="wrap_content"
                                android:layout_height="wrap_content" android:text="08:00 AM"
                                android:textSize="16sp" android:fontFamily="@font/nunito" android:textStyle="bold"
                                android:textColor="@color/charcoal"/>
                        </LinearLayout>
                    </LinearLayout>
                    <Button android:id="@+id/btn_edit_schedule"
                        android:layout_width="match_parent" android:layout_height="44dp"
                        android:layout_marginTop="12dp" android:text="✏️ Edit Schedule"
                        android:background="@drawable/bg_btn_outline" android:textSize="14sp"
                        android:fontFamily="@font/nunito" android:textStyle="bold"
                        android:textColor="@color/charcoal" android:stateListAnimator="@null"/>
                </LinearLayout>
            </androidx.cardview.widget.CardView>



            <!-- Connect with Caregiver -->
            <androidx.cardview.widget.CardView android:id="@+id/card_connect_caregiver"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                app:cardCornerRadius="18dp" app:cardElevation="4dp"
                app:cardBackgroundColor="@color/white" android:layout_marginBottom="14dp">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="vertical" android:padding="18dp">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Connect with Caregiver" android:textSize="16sp"
                        android:fontFamily="@font/nunito" android:textStyle="bold"
                        android:textColor="@color/charcoal" android:layout_marginBottom="6dp"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Share your code so a caregiver can access your schedule"
                        android:textSize="13sp" android:textColor="@color/charcoal_light"
                        android:layout_marginBottom="12dp"/>
                    <LinearLayout android:layout_width="match_parent" android:layout_height="52dp"
                        android:background="@drawable/bg_code_display" android:paddingHorizontal="16dp"
                        android:gravity="center_vertical">
                        <TextView android:id="@+id/tv_profile_code" android:layout_width="0dp"
                            android:layout_height="wrap_content" android:layout_weight="1"
                            android:text="MED-XXXXX" android:textSize="20sp" android:textStyle="bold"
                            android:fontFamily="monospace" android:textColor="@color/charcoal"
                            android:letterSpacing="0.1"/>
                        <Button android:id="@+id/btn_copy_code" android:layout_width="48dp"
                            android:layout_height="48dp" android:text="📋" android:background="@null"
                            android:textSize="20sp" android:contentDescription="@string/copy_code"
                            android:stateListAnimator="@null"/>
                    </LinearLayout>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Dinner" android:textSize="11sp" android:textStyle="bold"
                        android:textColor="@color/charcoal_light" android:layout_marginTop="4dp"/>
                    <TextView android:id="@+id/tv_dinner_time" android:layout_width="wrap_content"
                        android:layout_height="wrap_content" android:text="07:30 PM"
                        android:textSize="16sp" android:fontFamily="@font/nunito" android:textStyle="bold"
                        android:textColor="@color/charcoal"/>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Settings -->
            <androidx.cardview.widget.CardView android:layout_width="match_parent"
                android:layout_height="wrap_content" app:cardCornerRadius="18dp"
                app:cardElevation="4dp" app:cardBackgroundColor="@color/white"
                android:layout_marginBottom="14dp">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="vertical" android:padding="18dp">
                    <LinearLayout
                        android:id="@+id/notification_settings_row"
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        android:gravity="center_vertical"
                        android:padding="4dp">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="🔔" android:textSize="22sp" android:layout_marginEnd="12dp"/>
                        <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                            android:layout_weight="1" android:text="Notification Settings"
                            android:textSize="15sp" android:fontFamily="@font/nunito" android:textStyle="bold"
                            android:textColor="@color/charcoal"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="›" android:textSize="20sp" android:textColor="@color/charcoal_light"/>
                    </LinearLayout>
                    <View android:layout_width="match_parent" android:layout_height="1dp"
                        android:background="@color/oat_dark"/>
                    <LinearLayout
                        android:id="@+id/help_support_row"
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        android:gravity="center_vertical"
                        android:padding="4dp">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="❓" android:textSize="22sp" android:layout_marginEnd="12dp"/>
                        <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                            android:layout_weight="1" android:text="Help &amp; Support"
                            android:textSize="15sp" android:fontFamily="@font/nunito" android:textStyle="bold"
                            android:textColor="@color/charcoal"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="›" android:textSize="20sp" android:textColor="@color/charcoal_light"/>
                    </LinearLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <Button android:id="@+id/btn_logout"
                android:layout_width="match_parent" android:layout_height="@dimen/btn_height_secondary"
                android:text="🚪 Log Out" android:background="@drawable/bg_btn_outline"
                android:textColor="@color/charcoal" android:textSize="16sp"
                android:fontFamily="@font/nunito" android:textStyle="bold"
                android:stateListAnimator="@null" android:layout_marginBottom="24dp"/>
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>
</LinearLayout>
